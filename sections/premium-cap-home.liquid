{% liquid
  assign model_collection = section.settings.model_collection
  assign model_limit = section.settings.model_limit | default: 8
  assign visible_model_count = model_collection.products_count | at_most: model_limit
  assign featured_model = model_collection.products.first
%}

<section class="premium-cap-home color-{{ section.settings.color_scheme }}">
  <div class="premium-cap-home__hero">
    <div class="premium-cap-home__hero-copy">
      {% if section.settings.eyebrow != blank %}
        <p class="premium-cap-home__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      <h1>{{ section.settings.heading | escape }}</h1>
      {% if section.settings.subheading != blank %}
        <div class="premium-cap-home__lead rte">{{ section.settings.subheading }}</div>
      {% endif %}
      {% if section.settings.hero_button_label != blank %}
        <a class="button" href="{{ section.settings.hero_button_link | default: '#cap-models' }}">
          {{ section.settings.hero_button_label | escape }}
        </a>
      {% endif %}
    </div>

    <div class="premium-cap-home__hero-media">
      {% if section.settings.hero_video != blank %}
        {{
          section.settings.hero_video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            playsinline: true,
            image_size: '1600x'
        }}
      {% elsif section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 1800
          | image_tag:
            widths: '750, 1100, 1500, 1800',
            sizes: '(min-width: 990px) 56vw, 100vw',
            loading: 'eager',
            fetchpriority: 'high',
            alt: section.settings.hero_image.alt
        }}
      {% else %}
        <img
          class="premium-cap-home__asset-image"
          src="{{ 'dad-hat.png' | asset_url }}"
          alt="Custom Dad Hat"
          width="1600"
          height="1600"
          loading="eager"
          fetchpriority="high"
        >
      {% endif %}
    </div>
  </div>

  <div class="premium-cap-home__content">
    <div id="cap-models" class="premium-cap-home__section">
      <div class="premium-cap-home__section-heading">
        <p class="premium-cap-home__kicker">{{ section.settings.models_eyebrow | escape }}</p>
        <h2>{{ section.settings.models_heading | escape }}</h2>
        {% if section.settings.models_text != blank %}
          <div class="rte">{{ section.settings.models_text }}</div>
        {% endif %}
      </div>

      {% assign dad_hat_product = model_collection.products[0] %}
      {% assign snapback_product = model_collection.products[1] %}
      <div class="premium-cap-home__model-grid" data-model-count="2">
        <a class="premium-cap-card" href="{% if dad_hat_product != blank %}{{ dad_hat_product.url }}{% else %}#cap-models{% endif %}">
          <div class="premium-cap-card__media">
            <img
              src="{{ 'dad-hat.png' | asset_url }}"
              alt="Custom Dad Hat"
              width="1200"
              height="1200"
              loading="lazy"
            >
          </div>
          <div class="premium-cap-card__details">
            <h3>{% if dad_hat_product != blank %}{{ dad_hat_product.title | escape }}{% else %}Dad Hat{% endif %}</h3>
            <span>{% if dad_hat_product != blank %}{{ dad_hat_product.price | money }}{% else %}Customizable model{% endif %}</span>
          </div>
        </a>

        <a class="premium-cap-card" href="{% if snapback_product != blank %}{{ snapback_product.url }}{% else %}#cap-models{% endif %}">
          <div class="premium-cap-card__media">
            <img
              src="{{ 'snapback.png' | asset_url }}"
              alt="Custom Snapback"
              width="1200"
              height="1200"
              loading="lazy"
            >
          </div>
          <div class="premium-cap-card__details">
            <h3>{% if snapback_product != blank %}{{ snapback_product.title | escape }}{% else %}Snapback{% endif %}</h3>
            <span>{% if snapback_product != blank %}{{ snapback_product.price | money }}{% else %}Customizable model{% endif %}</span>
          </div>
        </a>
      </div>
    </div>

    <div class="premium-cap-home__section premium-cap-home__steps">
      <div class="premium-cap-home__section-heading premium-cap-home__section-heading--center">
        <p class="premium-cap-home__kicker">{{ section.settings.steps_eyebrow | escape }}</p>
        <h2>{{ section.settings.steps_heading | escape }}</h2>
      </div>

      <div class="premium-cap-home__steps-grid">
        <article class="premium-cap-step">
          <span>01</span>
          <h3>{{ section.settings.step_1_heading | escape }}</h3>
          <p>{{ section.settings.step_1_text | escape }}</p>
        </article>
        <article class="premium-cap-step">
          <span>02</span>
          <h3>{{ section.settings.step_2_heading | escape }}</h3>
          <p>{{ section.settings.step_2_text | escape }}</p>
        </article>
        <article class="premium-cap-step">
          <span>03</span>
          <h3>{{ section.settings.step_3_heading | escape }}</h3>
          <p>{{ section.settings.step_3_text | escape }}</p>
        </article>
      </div>
    </div>

    <div class="premium-cap-home__section premium-cap-home__gallery-section">
      <div class="premium-cap-home__section-heading">
        <p class="premium-cap-home__kicker">{{ section.settings.gallery_eyebrow | escape }}</p>
        <h2>{{ section.settings.gallery_heading | escape }}</h2>
        {% if section.settings.gallery_text != blank %}
          <div class="rte">{{ section.settings.gallery_text }}</div>
        {% endif %}
      </div>

      <div class="premium-cap-home__gallery">
        <figure class="premium-cap-home__gallery-item">
          <img src="{{ 'dad-hat.png' | asset_url }}" alt="Dad Hat customization example" width="1200" height="1200" loading="lazy">
          <figcaption>Dad Hat</figcaption>
        </figure>
        <figure class="premium-cap-home__gallery-item">
          <img src="{{ 'snapback.png' | asset_url }}" alt="Snapback customization example" width="1200" height="1200" loading="lazy">
          <figcaption>Snapback</figcaption>
        </figure>
        <figure class="premium-cap-home__gallery-item premium-cap-home__gallery-item--pair">
          <img src="{{ 'dad-hat.png' | asset_url }}" alt="Custom cap collection" width="1200" height="1200" loading="lazy">
          <img src="{{ 'snapback.png' | asset_url }}" alt="" width="1200" height="1200" loading="lazy">
          <figcaption>Choose your shape</figcaption>
        </figure>
      </div>
    </div>

    <div class="premium-cap-home__final-cta">
      <div>
        <p class="premium-cap-home__kicker">{{ section.settings.cta_eyebrow | escape }}</p>
        <h2>{{ section.settings.cta_heading | escape }}</h2>
        {% if section.settings.cta_text != blank %}
          <div class="rte">{{ section.settings.cta_text }}</div>
        {% endif %}
      </div>
      {% if section.settings.cta_button_label != blank %}
        <a class="button button-secondary" href="{{ section.settings.cta_button_link | default: '#cap-models' }}">
          {{ section.settings.cta_button_label | escape }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .premium-cap-home {
    background: var(--color-background);
    color: var(--color-foreground);
  }

  .premium-cap-home__hero {
    display: grid;
    min-height: min(820px, 88vh);
    background: #101010;
    color: #fff;
  }

  .premium-cap-home__hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 24px;
    padding: clamp(48px, 8vw, 120px) max(var(--page-margin), calc((100vw - var(--page-width)) / 2));
  }

  .premium-cap-home__hero-copy h1 {
    max-width: 12ch;
    margin: 0;
    color: inherit;
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.055em;
  }

  .premium-cap-home__lead {
    max-width: 52ch;
    color: rgb(255 255 255 / 0.76);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
  }

  .premium-cap-home__eyebrow,
  .premium-cap-home__kicker {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .premium-cap-home__hero-media {
    min-height: 460px;
    overflow: hidden;
    background: #262626;
  }

  .premium-cap-home__hero-media img,
  .premium-cap-home__hero-media video,
  .premium-cap-home__media-placeholder,
  .premium-cap-home__media-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .premium-cap-home__hero-media .premium-cap-home__asset-image {
    object-fit: contain;
    padding: clamp(24px, 5vw, 72px);
  }

  .premium-cap-home__media-placeholder {
    position: relative;
    display: grid;
    place-items: center;
  }

  .premium-cap-home__media-placeholder span {
    position: absolute;
    bottom: 24px;
    left: 24px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgb(0 0 0 / 0.65);
    color: #fff;
    font-size: 0.75rem;
  }

  .premium-cap-home__content {
    width: min(100% - (2 * var(--page-margin)), var(--page-width));
    margin-inline: auto;
  }

  .premium-cap-home__section {
    padding-block: clamp(72px, 10vw, 144px);
  }

  .premium-cap-home__section + .premium-cap-home__section {
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
  }

  .premium-cap-home__section-heading {
    display: grid;
    gap: 14px;
    max-width: 700px;
    margin-bottom: clamp(32px, 5vw, 64px);
  }

  .premium-cap-home__section-heading h2,
  .premium-cap-home__final-cta h2 {
    margin: 0;
    font-size: clamp(2.25rem, 5vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .premium-cap-home__section-heading--center {
    margin-inline: auto;
    text-align: center;
  }

  .premium-cap-home__model-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px 12px;
  }

  .premium-cap-card {
    display: grid;
    gap: 14px;
    color: inherit;
    text-decoration: none;
  }

  .premium-cap-card__media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 12px;
    background: rgb(var(--color-foreground-rgb) / 0.045);
  }

  .premium-cap-card__media img,
  .premium-cap-card__media svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: clamp(12px, 2vw, 28px);
    transition: transform 350ms ease;
  }

  .premium-cap-card:hover .premium-cap-card__media img {
    transform: scale(1.025);
  }

  .premium-cap-card__details {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }

  .premium-cap-card__details h3 {
    margin: 0;
    font-size: 1rem;
  }

  .premium-cap-card__details span {
    color: rgb(var(--color-foreground-rgb) / 0.65);
    font-size: 0.875rem;
    text-align: right;
  }

  .premium-cap-home__steps {
    text-align: center;
  }

  .premium-cap-home__steps-grid {
    display: grid;
    gap: 12px;
  }

  .premium-cap-step {
    min-height: 260px;
    padding: clamp(28px, 4vw, 48px);
    border-radius: 14px;
    background: rgb(var(--color-foreground-rgb) / 0.045);
  }

  .premium-cap-step span {
    display: block;
    margin-bottom: 64px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .premium-cap-step h3 {
    margin: 0 0 12px;
    font-size: clamp(1.35rem, 2vw, 2rem);
  }

  .premium-cap-step p {
    max-width: 32ch;
    margin: 0 auto;
    color: rgb(var(--color-foreground-rgb) / 0.68);
  }

  .premium-cap-home__gallery {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 82%;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
  }

  .premium-cap-home__gallery-item {
    position: relative;
    aspect-ratio: 4 / 5;
    margin: 0;
    overflow: hidden;
    border-radius: 14px;
    scroll-snap-align: start;
    background: rgb(var(--color-foreground-rgb) / 0.045);
  }

  .premium-cap-home__gallery-item img,
  .premium-cap-home__gallery-item svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: clamp(16px, 3vw, 36px);
  }

  .premium-cap-home__gallery-item--pair {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .premium-cap-home__gallery-item--pair img {
    min-width: 0;
  }

  .premium-cap-home__gallery-item figcaption {
    position: absolute;
    right: 16px;
    bottom: 16px;
    left: 16px;
    padding: 12px 14px;
    border-radius: 10px;
    background: rgb(0 0 0 / 0.58);
    color: #fff;
    backdrop-filter: blur(10px);
  }

  .premium-cap-home__final-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 36px;
    margin-bottom: var(--page-margin);
    padding: clamp(40px, 7vw, 88px);
    border-radius: 18px;
    background: #101010;
    color: #fff;
  }

  .premium-cap-home__final-cta > div {
    display: grid;
    gap: 16px;
    max-width: 760px;
  }

  .premium-cap-home__final-cta h2 {
    color: inherit;
  }

  .premium-cap-home__final-cta .rte {
    color: rgb(255 255 255 / 0.72);
  }

  @media screen and (min-width: 750px) {
    .premium-cap-home__hero {
      grid-template-columns: minmax(0, 44%) minmax(0, 56%);
    }

    .premium-cap-home__model-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .premium-cap-home__model-grid[data-model-count='1'] {
      grid-template-columns: minmax(0, 1fr);
      max-width: 720px;
    }

    .premium-cap-home__model-grid[data-model-count='2'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .premium-cap-home__model-grid[data-model-count='3'] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .premium-cap-home__steps-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .premium-cap-home__gallery {
      grid-auto-flow: initial;
      grid-auto-columns: initial;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      overflow: visible;
    }

    .premium-cap-home__gallery-item:nth-child(2) {
      transform: translateY(40px);
    }

    .premium-cap-home__final-cta {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  @media screen and (max-width: 749px) {
    .premium-cap-home__hero-copy {
      order: 2;
    }

    .premium-cap-home__hero-media {
      min-height: 55vh;
    }
  }
{% endstylesheet %}

